# ═══════════════════════════════════════════════════════════════════════════════
# Teachers-app — docker-compose env vars
# Copy to .env and fill in the values before running: docker-compose up
# ═══════════════════════════════════════════════════════════════════════════════

# ── Clerk (backend) ─────────────────────────────────────────────────────────
# Clerk Dashboard → Your app → API Keys → Advanced → JWKS URI
CLERK_JWKS_URI=https://your-clerk-domain.clerk.accounts.dev/.well-known/jwks.json

# Decode a real Clerk session token at jwt.io → copy the "iss" field
CLERK_ISSUER_URI=https://your-clerk-domain.clerk.accounts.dev

# Clerk Dashboard → Webhooks → your endpoint → Signing Secret  (format: whsec_...)
# Webhook endpoint to register: https://your-domain.com/api/clerk/webhooks
# Events to subscribe: user.created, user.updated
CLERK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# ── Clerk (frontend-web, baked into Vite build) ──────────────────────────────
# Clerk Dashboard → Your app → API Keys → Publishable key
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx

# ── API URL used by the Vite build ────────────────────────────────────────────
# In production with docker-compose, nginx proxies /api → backend, so use /api
VITE_API_URL=/api

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the Spring Boot backend
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000
