# ── Database ────────────────────────────────────────────────────────────────
SPRING_DATASOURCE_PASSWORD=your_postgres_password

# ── Clerk auth ───────────────────────────────────────────────────────────────
# CLERK_JWKS_URI: Clerk Dashboard → Your app → API Keys → Advanced → JWKS URI
# Format: https://<your-clerk-domain>.clerk.accounts.dev/.well-known/jwks.json
CLERK_JWKS_URI=https://your-clerk-domain.clerk.accounts.dev/.well-known/jwks.json

# CLERK_ISSUER_URI: decode a real Clerk session token at jwt.io → copy the "iss" field
# Typically: https://<your-clerk-frontend-api> (different from JWKS domain)
CLERK_ISSUER_URI=https://your-clerk-domain.clerk.accounts.dev

# CLERK_WEBHOOK_SECRET: Clerk Dashboard → Webhooks → your endpoint → Signing Secret
# Format: whsec_xxxxxxxxxxxxxxxxxxxx
CLERK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# ── Server ────────────────────────────────────────────────────────────────────
# Public base URL used for avatar image links (stored in DB)
APP_PUBLIC_BASE_URL=http://localhost:8080

# ── Uploads ───────────────────────────────────────────────────────────────────
# Avatar uploads directory (defaults to ~/Teachers-app-uploads/avatars if unset)
# APP_UPLOADS_DIR=/path/to/uploads/avatars